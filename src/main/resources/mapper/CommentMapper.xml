<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheima.logmanagementsystem.mapper.CommentMapper">

    <resultMap id="BaseResultMap" type="com.itheima.logmanagementsystem.entity.Comment">
        <id column="comment_id" property="commentId" />
        <result column="article_id" property="articleId" />
        <result column="user_id" property="userId" />
        <result column="content" property="content" />
        <result column="parent_id" property="parentId" />
        <result column="create_time" property="createTime" />
        <result column="real_name" property="userName" />
        <result column="avatar_url" property="userAvatar" />
    </resultMap>

    <select id="findByArticleId" resultMap="BaseResultMap">
        SELECT c.*, u.real_name, u.avatar_url
        FROM sys_comment c
        LEFT JOIN sys_user u ON c.user_id = u.user_id
        WHERE c.article_id = #{articleId}
        ORDER BY c.create_time ASC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="commentId">
        INSERT INTO sys_comment (article_id, user_id, content, parent_id, create_time)
        VALUES (#{articleId}, #{userId}, #{content}, #{parentId}, NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM sys_comment WHERE comment_id = #{commentId}
    </delete>

    <delete id="deleteByArticleId">
        DELETE FROM sys_comment WHERE article_id = #{articleId}
    </delete>

</mapper>
